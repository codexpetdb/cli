{
  "name": "petdb",
  "version": "1.0.0",
  "description": "Install verified Codex pets from CodexPetDB.",
  "type": "module",
  "bin": {
    "petdb": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check .",
    "deploy:manual": "node scripts/deploy-manual.mjs",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "prepack": "pnpm build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^20.19.0",
    "lefthook": "^2.1.10",
    "typescript": "^5.7.2",
    "vitest": "~3.2.4"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.13.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": ".",
    "type": "git",
    "url": "git+https://github.com/codexpetdb/cli.git"
  },
  "bugs": {
    "url": "https://github.com/codexpetdb/cli/issues"
  },
  "homepage": "https://github.com/codexpetdb/cli#readme"
}
