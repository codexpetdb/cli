{
  "components": {
    "schemas": {
      "ApiProblem": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "minLength": 1,
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "requestId": {
            "minLength": 1,
            "type": "string"
          },
          "status": {
            "maximum": 599,
            "minimum": 400,
            "type": "integer"
          },
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "type": {
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "code",
          "detail",
          "requestId",
          "status",
          "title",
          "type"
        ],
        "type": "object"
      },
      "CliCurrentUserResponse": {
        "additionalProperties": false,
        "properties": {
          "data": {
            "additionalProperties": false,
            "properties": {
              "email": {
                "format": "email",
                "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
                "type": "string"
              },
              "expiresAt": {
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "uid": {
                "maxLength": 32,
                "minLength": 3,
                "pattern": "^[A-Za-z0-9._~*-]+$",
                "type": "string"
              }
            },
            "required": [
              "email",
              "expiresAt",
              "name",
              "uid"
            ],
            "type": "object"
          }
        },
        "required": [
          "data"
        ],
        "type": "object"
      },
      "CliDeviceCodeRequest": {
        "additionalProperties": false,
        "properties": {
          "client_id": {
            "const": "petdb-cli",
            "type": "string"
          },
          "scope": {
            "const": "petdb:read petdb:write",
            "type": "string"
          }
        },
        "required": [
          "client_id",
          "scope"
        ],
        "type": "object"
      },
      "CliDeviceCodeResponse": {
        "additionalProperties": false,
        "properties": {
          "device_code": {
            "minLength": 1,
            "type": "string"
          },
          "expires_in": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "interval": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "user_code": {
            "minLength": 1,
            "type": "string"
          },
          "verification_uri": {
            "format": "uri",
            "type": "string"
          },
          "verification_uri_complete": {
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "device_code",
          "expires_in",
          "interval",
          "user_code",
          "verification_uri",
          "verification_uri_complete"
        ],
        "type": "object"
      },
      "CliDeviceError": {
        "additionalProperties": false,
        "properties": {
          "error": {
            "enum": [
              "access_denied",
              "authorization_pending",
              "expired_token",
              "invalid_client",
              "invalid_grant",
              "invalid_request",
              "slow_down"
            ],
            "type": "string"
          },
          "error_description": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "error_description"
        ],
        "type": "object"
      },
      "CliDeviceTokenRequest": {
        "additionalProperties": false,
        "properties": {
          "client_id": {
            "const": "petdb-cli",
            "type": "string"
          },
          "device_code": {
            "minLength": 1,
            "type": "string"
          },
          "grant_type": {
            "const": "urn:ietf:params:oauth:grant-type:device_code",
            "type": "string"
          }
        },
        "required": [
          "client_id",
          "device_code",
          "grant_type"
        ],
        "type": "object"
      },
      "CliDeviceTokenResponse": {
        "additionalProperties": false,
        "properties": {
          "access_token": {
            "minLength": 1,
            "type": "string"
          },
          "expires_in": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "scope": {
            "const": "petdb:read petdb:write",
            "type": "string"
          },
          "token_type": {
            "const": "Bearer",
            "type": "string"
          }
        },
        "required": [
          "access_token",
          "expires_in",
          "scope",
          "token_type"
        ],
        "type": "object"
      },
      "CliEditSourceResponse": {
        "additionalProperties": false,
        "properties": {
          "data": {
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string"
              },
              "displayName": {
                "type": "string"
              },
              "formatVersion": {
                "anyOf": [
                  {
                    "const": 1,
                    "type": "number"
                  },
                  {
                    "const": 2,
                    "type": "number"
                  }
                ]
              },
              "manifest": {
                "additionalProperties": {},
                "propertyNames": {
                  "type": "string"
                },
                "type": "object"
              },
              "revisionId": {
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                "type": "string"
              },
              "spritesheet": {
                "additionalProperties": false,
                "properties": {
                  "byteSize": {
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991,
                    "type": "integer"
                  },
                  "contentType": {
                    "enum": [
                      "image/png",
                      "image/webp"
                    ],
                    "type": "string"
                  },
                  "sha256": {
                    "pattern": "^[a-f0-9]{64}$",
                    "type": "string"
                  },
                  "url": {
                    "format": "uri",
                    "type": "string"
                  }
                },
                "required": [
                  "byteSize",
                  "contentType",
                  "sha256",
                  "url"
                ],
                "type": "object"
              }
            },
            "required": [
              "description",
              "displayName",
              "formatVersion",
              "manifest",
              "revisionId",
              "spritesheet"
            ],
            "type": "object"
          }
        },
        "required": [
          "data"
        ],
        "type": "object"
      },
      "CliFinalizeResponse": {
        "additionalProperties": false,
        "properties": {
          "data": {
            "additionalProperties": false,
            "properties": {
              "assets": {
                "additionalProperties": {
                  "additionalProperties": false,
                  "properties": {
                    "byteSize": {
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991,
                      "type": "integer"
                    },
                    "sha256": {
                      "pattern": "^[a-f0-9]{64}$",
                      "type": "string"
                    }
                  },
                  "required": [
                    "byteSize",
                    "sha256"
                  ],
                  "type": "object"
                },
                "propertyNames": {
                  "type": "string"
                },
                "type": "object"
              },
              "reviewStatus": {
                "const": "queued",
                "type": "string"
              },
              "revisionId": {
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                "type": "string"
              },
              "status": {
                "const": "pending",
                "type": "string"
              }
            },
            "required": [
              "assets",
              "reviewStatus",
              "revisionId",
              "status"
            ],
            "type": "object"
          }
        },
        "required": [
          "data"
        ],
        "type": "object"
      },
      "CliPetRevisionRequest": {
        "additionalProperties": false,
        "properties": {
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "displayName": {
            "minLength": 1,
            "type": "string"
          },
          "files": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/CliUploadFileDeclaration"
            },
            "maxItems": 3,
            "type": "array"
          },
          "manifest": {
            "additionalProperties": {},
            "propertyNames": {
              "type": "string"
            },
            "type": "object"
          },
          "sourceRevisionId": {
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "type": "string"
          }
        },
        "required": [
          "sourceRevisionId"
        ],
        "type": "object"
      },
      "CliPetSubmissionRequest": {
        "additionalProperties": false,
        "properties": {
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "displayName": {
            "minLength": 1,
            "type": "string"
          },
          "files": {
            "items": {
              "$ref": "#/components/schemas/CliUploadFileDeclaration"
            },
            "maxItems": 3,
            "minItems": 3,
            "type": "array"
          },
          "formatVersion": {
            "anyOf": [
              {
                "const": 1,
                "type": "number"
              },
              {
                "const": 2,
                "type": "number"
              }
            ]
          },
          "slug": {
            "maxLength": 32,
            "minLength": 3,
            "pattern": "^[A-Za-z0-9._~*-]+$",
            "type": "string"
          }
        },
        "required": [
          "description",
          "displayName",
          "files",
          "formatVersion",
          "slug"
        ],
        "type": "object"
      },
      "CliUploadFileDeclaration": {
        "additionalProperties": false,
        "properties": {
          "byteSize": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "contentType": {
            "enum": [
              "application/json",
              "image/png",
              "image/webp"
            ],
            "type": "string"
          },
          "filename": {
            "enum": [
              "pet.json",
              "poster.webp",
              "spritesheet.png",
              "spritesheet.webp"
            ],
            "type": "string"
          },
          "role": {
            "enum": [
              "manifest",
              "poster",
              "spritesheet"
            ],
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          }
        },
        "required": [
          "byteSize",
          "contentType",
          "filename",
          "role",
          "sha256"
        ],
        "type": "object"
      },
      "CliUploadSessionResponse": {
        "additionalProperties": false,
        "properties": {
          "data": {
            "additionalProperties": false,
            "properties": {
              "expiresAt": {
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                "type": "string"
              },
              "revisionId": {
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                "type": "string"
              },
              "uploadId": {
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                "type": "string"
              },
              "uploadTargets": {
                "items": {
                  "$ref": "#/components/schemas/CliUploadTarget"
                },
                "maxItems": 3,
                "type": "array"
              }
            },
            "required": [
              "expiresAt",
              "revisionId",
              "uploadId",
              "uploadTargets"
            ],
            "type": "object"
          }
        },
        "required": [
          "data"
        ],
        "type": "object"
      },
      "CliUploadTarget": {
        "additionalProperties": false,
        "properties": {
          "expiresAt": {
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
          },
          "headers": {
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            },
            "type": "object"
          },
          "method": {
            "const": "PUT",
            "type": "string"
          },
          "role": {
            "enum": [
              "manifest",
              "poster",
              "spritesheet"
            ],
            "type": "string"
          },
          "url": {
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "expiresAt",
          "headers",
          "method",
          "role",
          "url"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "CliBearer": {
        "bearerFormat": "Better Auth session",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Stable JSON control-plane contract used by the PetDB CLI.",
    "title": "CodexPetDB CLI API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/auth/device/code": {
      "post": {
        "operationId": "createCliDeviceCode",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CliDeviceCodeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceCodeResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceError"
                }
              }
            },
            "description": "Invalid device authorization request"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceError"
                }
              }
            },
            "description": "Rate limit exceeded"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceError"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "security": [],
        "summary": "Create a CLI device authorization code",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/device/token": {
      "post": {
        "operationId": "pollCliDeviceToken",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CliDeviceTokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceTokenResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceError"
                }
              }
            },
            "description": "Invalid device authorization request"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceError"
                }
              }
            },
            "description": "Rate limit exceeded"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliDeviceError"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "security": [],
        "summary": "Exchange an approved device code for a session token",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/user/me": {
      "get": {
        "operationId": "getCliCurrentUser",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliCurrentUserResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Authentication required"
          },
          "429": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Rate limit exceeded"
          },
          "503": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "CliBearer": []
          }
        ],
        "summary": "Get the current CLI user",
        "tags": [
          "User"
        ]
      }
    },
    "/api/v1/user/pet-submissions": {
      "post": {
        "operationId": "createCliPetSubmission",
        "parameters": [
          {
            "description": "Stable key used to retry this create operation.",
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CliPetSubmissionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliUploadSessionResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CliUploadSessionResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Authentication required"
          },
          "409": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Resource state conflict"
          },
          "413": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Upload is too large"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Request validation failed"
          },
          "429": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Rate limit exceeded"
          },
          "503": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "security": [
          {
            "CliBearer": []
          }
        ],
        "summary": "Create a new pet submission upload",
        "tags": [
          "User"
        ]
      }
    },
    "/api/v1/user/pet-uploads/{uploadId}": {
      "delete": {
        "operationId": "abortCliPetUpload",
        "parameters": [
          {
            "in": "path",
            "name": "uploadId",
            "required": true,
            "schema": {
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful response"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Authentication required"
          },
          "404": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiProblem"
                }
              }
            },
            "description": "Resource not found"
          },
