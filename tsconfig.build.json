{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "exclude": ["test/**/*.ts"],
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true
  }
}
